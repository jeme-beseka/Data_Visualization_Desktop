<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>


<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.datavisualizer.controller.MainController"
      spacing="0"
      style="-fx-background-color: #f5f5f5;">
    
    <stylesheets>
        <String fx:value="/css/styles.css"/>
    </stylesheets>
    
    <!-- Top Toolbar -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="hbox-toolbar" style="-fx-padding: 12; -fx-background-color: white; -fx-border-color: #ecf0f1; -fx-border-width: 0 0 1 0;">
        
        <!-- File Operations -->
        <Button fx:id="loadButton" text="📁 Load CSV" onAction="#handleLoadCSV" styleClass="button-primary" style="-fx-padding: 8 16 8 16;"/>
        <Button fx:id="manualInputButton" text="✏️ Manual Input" onAction="#handleManualInput" styleClass="button-primary" style="-fx-padding: 8 16 8 16;"/>
        
        <Separator orientation="VERTICAL" style="-fx-padding: 0 5 0 5;"/>
        
        <!-- Chart Configuration -->
        <Label text="📊 Chart Type:" styleClass="label-header" style="-fx-font-size: 12px;"/>
        <ComboBox fx:id="chartTypeCombo" prefWidth="140" style="-fx-padding: 6;"/>
        
        <Label text="X-Axis:" styleClass="label-header" style="-fx-font-size: 12px;"/>
        <ComboBox fx:id="xAxisCombo" prefWidth="120" style="-fx-padding: 6;"/>
        
        <Label text="Y-Axis:" styleClass="label-header" style="-fx-font-size: 12px;"/>
        <ComboBox fx:id="yAxisCombo" prefWidth="120" style="-fx-padding: 6;"/>
        
        <Button fx:id="plotButton" text="📈 Plot" onAction="#handlePlot" styleClass="button-success" style="-fx-padding: 8 16 8 16;"/>
        
        <Separator orientation="VERTICAL" style="-fx-padding: 0 5 0 5;"/>
        
        <!-- Export and Settings -->
        <Button fx:id="saveButton" text="💾 Save Plot" onAction="#handleSavePlot" styleClass="button-secondary" style="-fx-padding: 8 16 8 16;"/>
        
        <Separator orientation="VERTICAL" style="-fx-padding: 0 5 0 5;"/>
        
        <Label text="🎨 Color:" styleClass="label-header" style="-fx-font-size: 12px;"/>
        <ColorPicker fx:id="chartColorPicker" prefWidth="100" style="-fx-padding: 6;"/>
        
        <Button fx:id="themeButton" text="🌙 Theme" onAction="#handleThemeToggle" styleClass="button-secondary" style="-fx-padding: 8 16 8 16;"/>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <Button fx:id="resetButton" text="🔄 Reset" onAction="#handleReset" styleClass="button-danger" style="-fx-padding: 8 16 8 16;"/>
    </HBox>
    
    <!-- Main Content Area -->
    <HBox spacing="12" VBox.vgrow="ALWAYS" style="-fx-padding: 12;">
        
        <!-- Left Sidebar - Data Preview and Stats -->
        <VBox spacing="12" style="-fx-min-width: 280; -fx-max-width: 350; -fx-background-color: white; -fx-border-radius: 8; -fx-padding: 12;">
            
            <!-- Data Info Section -->
            <VBox spacing="8" style="-fx-border-color: #ecf0f1; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 12 0;">
                <Label text="📊 Data Summary" styleClass="label-header" style="-fx-font-size: 13px;"/>
                <Label fx:id="dataRowsLabel" text="Rows: 0" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <Label fx:id="dataColumnsLabel" text="Columns: 0" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <Label fx:id="dataStatusLabel" text="Status: No data loaded" style="-fx-font-size: 12px; -fx-text-fill: #e74c3c;"/>
            </VBox>
            
            <!-- Data Preview Table -->
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <Label text="📋 Data Preview" styleClass="label-header" style="-fx-font-size: 13px;"/>
                <TableView fx:id="dataPreviewTable" prefHeight="200" style="-fx-font-size: 11px;">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                </TableView>
            </VBox>
            
            <!-- Statistics Section -->
            <VBox spacing="8" style="-fx-border-color: #ecf0f1; -fx-border-width: 1 0 0 0; -fx-padding: 12 0 0 0;">
                <Label text="📈 Statistics" styleClass="label-header" style="-fx-font-size: 13px;"/>
                <ScrollPane style="-fx-fit-to-width: true; -fx-padding: 0;">
                    <VBox fx:id="statsContainer" spacing="8" style="-fx-padding: 5;"/>
                </ScrollPane>
            </VBox>
        </VBox>
        
        <!-- Right Side - Chart Display -->
        <HBox spacing="0" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-border-radius: 8;">
            <!-- Chart Container -->
            <StackPane fx:id="chartContainer" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" minHeight="400" minWidth="500" style="-fx-background-color: white; -fx-padding: 12;"/>
            
            <!-- Legend Area - Hidden (functionality preserved via tooltips) -->
            <VBox fx:id="legendContainer" prefWidth="0" visible="false" managed="false" style="-fx-background-color: #f8f9fa; -fx-border-color: #ecf0f1; -fx-border-width: 0 0 0 1; -fx-padding: 10;">
                <Label text="Legend" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333; -fx-padding: 0 0 8 0;"/>
                <ScrollPane fx:id="legendScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <VBox fx:id="legendContent" spacing="4"/>
                </ScrollPane>
            </VBox>
        </HBox>
    </HBox>
    
    <!-- Status Bar -->
    <HBox spacing="20" styleClass="status-bar" style="-fx-padding: 8 12 8 12; -fx-background-color: #f8f9fa; -fx-border-color: #ecf0f1; -fx-border-width: 1 0 0 0;">
        <Label fx:id="statusLabel" text="Ready" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Data Visualizer v2.0" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
    </HBox>
    
</VBox>