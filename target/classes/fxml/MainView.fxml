<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.datavisualizer.controller.MainController"
      spacing="10">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="loadButton" text="📁 Load CSV" onAction="#handleLoadCSV"/>
        <Button fx:id="manualInputButton" text="Manual Input" onAction="#handleManualInput"/>
        <Separator orientation="VERTICAL"/>
        <Label text="📊 Chart Type:"/>
        <ComboBox fx:id="chartTypeCombo" prefWidth="150"/>
        <Label text="X-Axis:"/>
        <ComboBox fx:id="xAxisCombo" prefWidth="150"/>
        <Label text="Y-Axis:"/>
        <ComboBox fx:id="yAxisCombo" prefWidth="150"/>
        <Button fx:id="plotButton" text="Plot" onAction="#handlePlot"/>
        <Button fx:id="saveButton" text="💾 Save Plot" onAction="#handleSavePlot"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="resetButton" text="Reset" onAction="#handleReset" style="-fx-background-color: #ff6b6b; -fx-text-fill: white;"/>
    </HBox>
    
    <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS" minHeight="400" minWidth="600" style="-fx-background-color: white;"/>
    
</VBox>