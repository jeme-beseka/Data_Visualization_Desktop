<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.datavisualizer.controller.LandingController"
      alignment="CENTER"
      spacing="30"
      style="-fx-background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>
    
    <VBox alignment="CENTER" spacing="20" style="-fx-background-color: rgba(255, 255, 255, 0.95); -fx-background-radius: 20; -fx-padding: 40;">
        
        <!-- Title -->
        <Label text="Data Visualizer" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        
        <!-- Subtitle -->
        <Label text="Transform Your Data Into Beautiful Charts" 
               style="-fx-font-size: 20px; -fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
        
        <!-- Features -->
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 20 0 20 0;">
            <HBox alignment="CENTER" spacing="15">
                <Label text="📊" style="-fx-font-size: 24px;"/>
                <Label text="Multiple Chart Types" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
            </HBox>
            <HBox alignment="CENTER" spacing="15">
                <Label text="📁" style="-fx-font-size: 24px;"/>
                <Label text="CSV File Import" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
            </HBox>
            <HBox alignment="CENTER" spacing="15">
                <Label text="✏️" style="-fx-font-size: 24px;"/>
                <Label text="Manual Data Entry" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
            </HBox>
            <HBox alignment="CENTER" spacing="15">
                <Label text="💾" style="-fx-font-size: 24px;"/>
                <Label text="Export Charts as Images" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
            </HBox>
        </VBox>
        
        <!-- Get Started Button -->
        <Button fx:id="getStartedButton" 
                text="Get Started" 
                onAction="#handleGetStarted"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 15 30 15 30; -fx-background-radius: 25; -fx-cursor: hand;"
                onMouseEntered="#handleButtonHover"
                onMouseExited="#handleButtonExit"/>
        
        <!-- Version info -->
        <Label text="Version 1.0" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-padding: 20 0 0 0;"/>
        
    </VBox>
    
</VBox>