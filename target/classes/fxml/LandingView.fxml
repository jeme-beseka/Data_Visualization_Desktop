<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.datavisualizer.controller.LandingController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: transparent; -fx-background: transparent;">

    <VBox alignment="CENTER"
          spacing="0"
          style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    
        <stylesheets>
            <String fx:value="/css/styles.css"/>
        </stylesheets>
    
        <padding>
            <Insets top="25" right="40" bottom="25" left="40"/>
        </padding>
    
        <VBox alignment="CENTER" spacing="18" styleClass="vbox-card" style="-fx-background-color: rgba(255, 255, 255, 0.98); -fx-padding: 30;">
        
        <!-- Logo/Icon Area -->
        <VBox alignment="CENTER" spacing="10">
            <ImageView fitHeight="140" fitWidth="140" preserveRatio="true">
                <Image url="@/images/Data-Visual-Icon.png"/>
            </ImageView>
        </VBox>
        
        <!-- Title -->
        <Label text="King Data Visualizer" styleClass="label-title" style="-fx-font-size: 40px;"/>
        
        <!-- Subtitle -->
        <Label text="Transform Your Data Into Beautiful Charts" 
               styleClass="label-subtitle"
               style="-fx-font-size: 16px; -fx-font-style: italic;"/>
        
        <!-- Divider -->
        <Separator style="-fx-padding: 5 0 5 0;"/>
        
        <!-- Features Grid -->
        <GridPane hgap="30" vgap="15" style="-fx-padding: 10 0 10 0;">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>
            
            <!-- Feature 1 -->
            <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="📊" style="-fx-font-size: 32px;"/>
                <Label text="7+ Chart Types" styleClass="label-header"/>
                <Label text="Line, Bar, Scatter, Area, Heatmaps, Radar and Pie charts" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-wrap-text: true;"/>
            </VBox>
            
            <!-- Feature 2 -->
            <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="📁" style="-fx-font-size: 32px;"/>
                <Label text="CSV Import" styleClass="label-header"/>
                <Label text="Load data from CSV files instantly" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-wrap-text: true;"/>
            </VBox>
            
            <!-- Feature 3 -->
            <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="✏️" style="-fx-font-size: 32px;"/>
                <Label text="Manual Entry" styleClass="label-header"/>
                <Label text="Enter data directly in the app" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-wrap-text: true;"/>
            </VBox>
            
            <!-- Feature 4 -->
            <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="💾" style="-fx-font-size: 32px;"/>
                <Label text="Export Charts" styleClass="label-header"/>
                <Label text="Save visualizations as PNG images" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-wrap-text: true;"/>
            </VBox>
        </GridPane>
        
        <!-- Divider -->
        <Separator style="-fx-padding: 5 0 5 0;"/>
        
        <!-- Get Started Button -->
        <Button fx:id="getStartedButton" 
                text="Get Started →" 
                onAction="#handleGetStarted"
                styleClass="button-primary"
                style="-fx-font-size: 16px; -fx-padding: 12 35 12 35; -fx-background-radius: 8;"
                onMouseEntered="#handleButtonHover"
                onMouseExited="#handleButtonExit"/>
        
        <!-- Version info -->
        <Label text="Version 3.3 • Enhanced with Modern UI" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6; -fx-padding: 5 0 0 0;"/>
        
        </VBox>
    
    </VBox>

</ScrollPane>